---
import { ClientRouter } from "astro:transitions";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <ClientRouter fallback="swap" />
    <!-- Prevent FOUC: apply dark class before paint -->
    <script is:inline>
      const theme = (() => {
        const stored = localStorage?.getItem("theme") ?? "";
        if (["dark", "light"].includes(stored)) return stored;
        if (window.matchMedia("(prefers-color-scheme: dark)").matches)
          return "dark";
        return "light";
      })();
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
    <!-- Loading screen: injected in head so it renders before body CSS -->
    <script is:inline>
      if (!sessionStorage.getItem("loading-screen-done")) {
        var s = document.createElement("style");
        s.id = "loading-screen-inline";
        s.textContent =
          "#loading-screen{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:#FAFAFA;transition:opacity .4s ease}" +
          ".dark #loading-screen{background:#0F1117}" +
          "#loading-screen.is-hidden{opacity:0;pointer-events:none}" +
          "#loading-bar{width:120px;height:3px;border-radius:999px;background:#E4E4E7;overflow:hidden}" +
          ".dark #loading-bar{background:#27272A}" +
          '#loading-bar::after{content:"";display:block;height:100%;width:0;border-radius:999px;background:#AACDDC;animation:ldfill .8s ease-in-out forwards}' +
          ".dark #loading-bar::after{background:#8BB8CC}" +
          "@keyframes ldfill{to{width:100%}}";
        document.head.appendChild(s);
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <div id="loading-screen" aria-hidden="true">
      <div id="loading-bar"></div>
    </div>
    <Header />
    <main class="flex-1" transition:animate="fade">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      // Loading screen: show only on first visit per session
      (function () {
        var ls = document.getElementById("loading-screen");
        if (!ls) return;

        if (sessionStorage.getItem("loading-screen-done")) {
          ls.remove();
          return;
        }

        window.addEventListener("load", function () {
          setTimeout(function () {
            ls.classList.add("is-hidden");
            sessionStorage.setItem("loading-screen-done", "1");
            setTimeout(function () {
              ls.remove();
              var s = document.getElementById("loading-screen-inline");
              if (s) s.remove();
            }, 500);
          }, 200);
        });
      })();

      // IntersectionObserver for scroll-triggered animations
      document.addEventListener("astro:page-load", function () {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
        );

        document.querySelectorAll("[data-animate]").forEach(function (el) {
          observer.observe(el);
        });
      });

      // Re-apply dark mode class after View Transition swap
      document.addEventListener("astro:after-swap", function () {
        var theme = localStorage.getItem("theme");
        var isDark =
          theme === "dark" ||
          (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", isDark);
      });

      // Update active nav link after navigation
      document.addEventListener("astro:after-swap", function () {
        var path = window.location.pathname;
        document.querySelectorAll("header nav a").forEach(function (link) {
          var href = link.getAttribute("href");
          if (!href) return;
          var isActive =
            path === href || (href !== "/" && path.startsWith(href));
          if (isActive) {
            link.className =
              "px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200 text-primary bg-primary/10";
          } else {
            link.className =
              "px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200 text-muted hover:text-(--color-foreground) hover:bg-border/50";
          }
        });
      });
    </script>
  </body>
</html>
